{
  "name": "scriptorium",
  "version": "1.0.0",
  "description": "Medieval scribe idle clicker game",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "e2e": "yarn build && playwright test",
    "e2e:ui": "yarn build && playwright test --ui",
    "e2e:debug": "yarn build && playwright test --debug",
    "prepare": "husky"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "electron": "^41.1.1",
    "electron-vite": "^5.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lucide": "^1.7.0",
    "playwright": "^1.59.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
